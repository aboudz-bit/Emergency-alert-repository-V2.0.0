modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["bash", "-c", "cd artifacts/boutique-server && NODE_ENV=production npx tsx server/index.ts & node artifacts/api-server/dist/index.cjs"]
build = ["pnpm", "--filter", "@workspace/api-server", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Boutique Server"

[[workflows.workflow]]
name = "Boutique Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/boutique-server && NODE_ENV=production npx tsx server/index.ts"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
