{
  "expo": {
    "name": "KEAS",
    "slug": "keas-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "keas",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F6F8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.khurais.keas",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "KEAS needs your location to show nearby emergency zones and shelters.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "KEAS needs your location to track personnel during emergencies.",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "com.khurais.keas",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#5B3A8E"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://keas.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "KEAS needs your location to track personnel during emergencies.",
          "locationWhenInUsePermission": "KEAS needs your location to show nearby emergency zones and shelters.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "d42560c4-d28e-4520-960d-722357272df4"
      }
    },
    "owner": "mirza-12"
  }
}
